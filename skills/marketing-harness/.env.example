# GPT Image skill/CLI credentials. Keep real values in .env only.
# The harness does not call OpenAI directly; the gpt-image CLI may read these.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# Optional local image skill CLI provider. If unset, the harness searches for
# gpt-image on PATH, then ~/.codex/skills/gpt-image/scripts/generate.py.
HARNESS_SKILL_CLI_COMMAND=

# Optional CDN / object storage publishing.
HARNESS_CDN_BUCKET=
HARNESS_CDN_ENDPOINT=
HARNESS_CDN_BASE_URL=
HARNESS_CDN_PREFIX=marketing-harness
HARNESS_CDN_ACCESS_KEY_ID=
HARNESS_CDN_SECRET_ACCESS_KEY=
HARNESS_CDN_REGION=us-east-1

# Optional release output directory.
HARNESS_RELEASE_DIR=releases

# Optional repo-backed publish directory. In a consuming repo this is usually
# a separate asset git repository or submodule mounted at ./published.
HARNESS_REPO_PUBLISH_DIR=published

# Optional external style producer command. The command reads JSON from stdin and
# writes a complete brand.lock YAML/JSON document to stdout.
HARNESS_STYLE_PRODUCER_CMD=
