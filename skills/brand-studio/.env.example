# GPT Image skill/CLI credentials. Keep real values in .env only.
# The studio does not call OpenAI directly; the gpt-image CLI may read these.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# Optional local image skill CLI provider. If unset, the studio searches for
# gpt-image on PATH, then ~/.codex/skills/gpt-image/scripts/generate.py.
BRAND_STUDIO_SKILL_CLI_COMMAND=

# Optional CDN / object storage publishing.
BRAND_STUDIO_CDN_BUCKET=
BRAND_STUDIO_CDN_ENDPOINT=
BRAND_STUDIO_CDN_BASE_URL=
BRAND_STUDIO_CDN_PREFIX=brand-studio
BRAND_STUDIO_CDN_ACCESS_KEY_ID=
BRAND_STUDIO_CDN_SECRET_ACCESS_KEY=
BRAND_STUDIO_CDN_REGION=us-east-1

# Optional release output directory.
BRAND_STUDIO_RELEASE_DIR=releases

# Optional repo-backed publish directory. In a consuming repo this is usually
# a separate asset git repository or submodule mounted at ./published.
BRAND_STUDIO_REPO_PUBLISH_DIR=published

# Optional external style producer command. The command reads JSON from stdin and
# writes a complete brand.lock YAML/JSON document to stdout.
BRAND_STUDIO_STYLE_PRODUCER_CMD=
